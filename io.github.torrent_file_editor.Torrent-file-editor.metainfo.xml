<component type="desktop-application">
  <id>io.github.torrent_file_editor.Torrent-file-editor</id>
  <launchable type="desktop-id">io.github.torrent_file_editor.Torrent-file-editor.desktop</launchable>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later AND BSD-2-Clause</project_license>
  <name>Torrent File Editor</name>
  <summary>Edit and create torrent files</summary>

  <developer id="io.github.drizt">
    <name>Ivan Romanov</name>
  </developer>
  <update_contact>drizt72@zoho.eu</update_contact>

  <description>
    <p>
    Tool designed to create and edit torrent files. It shows the full contents of a
    torrent files or any bencode files and allows changing any fields.
    </p>
    <p>
    The main features.
    </p>
    <ul>
      <li>Create torrent files from scratch</li>
      <li>Edit torrent files in a user-friendly way</li>
      <li>Edit torrent files in JSON format</li>
      <li>Add, remove and reorder files in a torrent</li>
      <li>Support for multiple encodings</li>
    </ul>
  </description>

  <branding>
    <color type="primary" scheme_preference="light">#43d760</color>
    <color type="primary" scheme_preference="dark">#28873b</color>
  </branding>

  <categories>
    <category>Utility</category>
    <category>Network</category>
